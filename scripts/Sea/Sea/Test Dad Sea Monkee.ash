eaze	Stench	Sleaze	Hot	Physical	Cold	Stench";	lines[608] = "Pulpy	swim	awful	void	warps	slowly	9	thoughts	12	head	";	lines[609] = "Physical	Physical	Cold	Hot	Stench	Spooky	Hot	Stench	Spooky	Sleaze	";	lines[610] = "Slimy	shamble	curious	blackness	shakes	slowly	18	eyes	16	forehead	";	lines[611] = "Sleaze	Cold	Physical	Spooky	Hot	Sleaze	Cold	Stench	Hot		";	lines[612] = "Rigid	shamble	terrible	emptiness	wobbles	slowly	40	sanity	13	throat	";	lines[613] = "Cold	Cold	Hot	Sleaze	Sleaze	Physical	Spooky	Stench	Spooky	Stench	";	lines[614] = "Horrifying	swim	terrible	Space	shakes	slowly	48	sixth sense	14	skull	";	lines[615] = "Spooky	Physical	Hot	Spooky	Cold	Physical	Sleaze	Stench	Stench	Hot	";	lines[616] = "Horrifying	skitter	frightening	void	shimmers	suddenly	34	thoughts	10	stomach	";	lines[617] = "Spooky	Hot	Spooky	Stench	Stench	Cold	Physical	Sleaze	Sleaze	Hot	Cold";	lines[618] = "Rotting	skitter	terrible	emptiness	shifts	slowly	24	thoughts	9	spleen	";	lines[619] = "Stench	Hot	Hot	Cold	Sleaze	Sleaze	Spooky	Physical	Spooky	Stench	Physical";	lines[620] = "Rigid	ooze	curious	Space	warps	suddenly	32	sanity	10	head	";	lines[621] = "Cold	Stench	Physical	Hot	Cold	Sleaze	Sleaze	Stench	Physical	Spooky	";			int attempts_processed = 0;	int weakness_attempts_correct = 0;	int clues_attempts_correct = 0;		int round_11_attempts_processed = 0;	int round_11_attempts_correct = 0;		int [int] each_round_failures;	for i from 0 upto 9	{		each_round_failures[i] = 0;	}		print("Verifying clues and weakness decoders with collected data...");	foreach i in lines	{		if (i % 2 != 0)			continue;		attempts_processed = attempts_processed + 1;				string[int] actual_clues = split_string(lines[i], "\t");		string[int] actual_elements = split_string(lines[i + 1], "\t");		string[int] guessed_elements = decodeWeaknesses(actual_clues, false);		string clue_string = createClueTextWithClues(actual_clues);		string[int] guessed_clues = decodeClues(clue_string, false);				boolean weaknesses_correct = true;		foreach j in actual_elements		{			if (j + 1 == 11)			{				round_11_attempts_processed = round_11_attempts_processed + 1;				if (guessed_elements[j] == actual_elements[j])					round_11_attempts_correct = round_11_attempts_correct + 1;				continue;			}			if (guessed_elements[j] != actual_elements[j])				weaknesses_correct = false;		}					boolean clues_correct = true;		foreach j in actual_clues		{			if (guessed_clues[j] != actual_clues[j])				clues_correct = false;		}		if (weaknesses_correct)			weakness_attempts_correct = weakness_attempts_correct + 1;		if (clues_correct)			clues_attempts_correct = clues_attempts_correct + 1;				if (!weaknesses_correct || !clues_correct)		{			print("Try " + i / 2 + " incorrect:", "red");			//printMap(clues, "Clue");			print("Clues: " + componentsJoinedByString(actual_clues, ", "));			if (!weaknesses_correct)			{				foreach j in actual_elements						print("Actual element round " + (j + 1) + ": " + actual_elements[j]);				foreach j in guessed_elements				{					if (j + 1 == 11)						continue;					if (count(actual_elements) > j && guessed_elements[j] != actual_elements[j])					{						each_round_failures[j] = each_round_failures[j] + 1;						print("Guessed element round " + (j + 1) + ": " + guessed_elements[j], "red");					}					else						print("Guessed element round " + (j + 1) + ": " + guessed_elements[j]);				}				print("");			}			if (!clues_correct)			{				foreach j in guessed_clues				{					if (count(actual_clues) > j && guessed_clues[j] != actual_clues[j])					{						each_round_failures[j] = each_round_failures[j] + 1;						print("Guessed clue round " + (j + 1) + ": " + guessed_clues[j], "red");					}					else						print("Guessed clue round " + (j + 1) + ": " + guessed_clues[j]);				}			}		}				}		string output_color = "black";	if (weakness_attempts_correct != attempts_processed)		output_color = "red";	print(weakness_attempts_correct + " out of " + attempts_processed + " weakness guess attempts correct. (" + (100.0 * to_float(weakness_attempts_correct) / to_float(attempts_processed)) + "%)", output_color);		output_color = "black";	if (clues_attempts_correct != attempts_processed)		output_color = "red";	print(clues_attempts_correct + " out of " + attempts_processed + " clue guess attempts correct. (" + (100.0 * to_float(clues_attempts_correct) / to_float(attempts_processed)) + "%)", output_color);			print("Optional: " + round_11_attempts_correct + " out of " + round_11_attempts_processed + " round 11 guess attempts correct. (" + (100.0 * to_float(round_11_attempts_correct) / to_float(round_11_attempts_processed)) + "%)");	print("");	foreach i in each_round_failures	{		if (each_round_failures[i] > 0)			print("Round " + (i + 1) + " failed " + each_round_failures[i] + " times.");	}}