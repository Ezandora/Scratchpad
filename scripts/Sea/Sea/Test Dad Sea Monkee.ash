/*	Test Dad Sea Monkee.ash	Version 1.0	Tests Fight Dad Seak Monkee.ash's clue and weakness predictions with known data.*/import "Fight Dad Sea Monkee.ash"void printMap(string [int] map, string name){	foreach i in map		print(name + " " + i + ": " + map[i]);}string createClueTextWithClues(string [int] clues){	string [string] is_or_are;	//Guessed, not spaded	is_or_are["brain"] = "Is";	is_or_are["mind"] = "Is";	is_or_are["reason"] = "Is";	is_or_are["sanity"] = "Is";	is_or_are["grasp on reality"] = "Is";	is_or_are["sixth sense"] = "Is";	is_or_are["eyes"] = "Are";	is_or_are["thoughts"] = "Are";	is_or_are["senses"] = "Are";	is_or_are["memories"] = "Are";	is_or_are["fears"] = "Are";	return "<table width=95% cellspacing=0 cellpadding=0><tr><td style=\"color: white;\" align=center bgcolor=blue><b>Combat!</b></td></tr><tr><td style=\"padding: 5px; border: 1px solid blue;\"><center><table><tr><td><center><table><tr><td><img id='monpic' src=\"http://images.kingdomofloathing.com/adventureimages/dad_machine.gif\" width=400 height=300></td><td valign=center></td></tr></table><br>You're fighting <span id='monname'> Dad Sea Monkee</span><p></center><blockquote>You step through the door into a silent room with featureless white walls. In the center there sits a massive machine, the source of the noise. Pipes lead from the machine to ports on the blackened walls, pumping strange liquids into and out of the tank.<p>In the tank, floating, almost peacefully, is Dad. His eyes are open but vacant. In them you see your reflection, standing in a tiny room. White. Silent. Black. Deafening.<p>The room is the machine occupies the room contains the machine contains the room describes the machine creates the room is the machine.<p>You shake your head and look above the tank, at the window into space. " + clues[0] + " forms " + clues[1] + " in the darkness, each more " + clues[2] + " than the last. The " + clues[3] + " " + clues[4] + ", " + clues[5] + " revealing " + clues[6] + "-dimensional monstrosities.<p>No. Look again. There is nothing. " + is_or_are[to_lower_case(clues[7])] + " your " + clues[7] + " betraying you? As if on cue, " + clues[8] + "-sided triangles materialize and then disappear. So impossible that your " + clues[9] + " throbs.<p>You have to end this.<br></blockquote><center><p>It gets the jump on you.<p><p><table><tr><td>The heat of a dying star scorches your neck.</td></tr></table>";}void main(){	if (true)	{		//Test a single sourced string:		
string test_string = "<table width=95% cellspacing=0 cellpadding=0><tr><td style=\"color: white;\" align=center bgcolor=blue><b>Combat!</b></td></tr><tr><td style=\"padding: 5px; border: 1px solid blue;\"><center><table><tr><td><center><table><tr><td><img id='monpic' src=\"http://images.kingdomofloathing.com/adventureimages/dad_machine.gif\" width=400 height=300></td><td valign=center></td></tr></table><br>You're fighting <span id='monname'> Dad Sea Monkee</span><p></center><blockquote>You step through the door into a silent room with featureless white walls. In the center there sits a massive machine, the source of the noise. Pipes lead from the machine to ports on the blackened walls, pumping strange liquids into and out of the tank.<p>In the tank, floating, almost peacefully, is Dad. His eyes are open but vacant. In them you see your reflection, standing in a tiny room. White. Silent. Black. Deafening.<p>The room is the machine occupies the room contains the machine contains the room describes the machine creates the room is the machine.<p>You shake your head and look above the tank, at the window into space. Horrifying forms float in the darkness, each more curious than the last. The blackness wobbles, suddenly revealing 3-dimensional monstrosities.<p>No. Look again. There is nothing. Is your grasp on reality betraying you? As if on cue, 14-sided triangles materialize and then disappear. So impossible that your head throbs.<p>You have to end this.<br></blockquote><center><p>It gets the jump on you.<p><p><table><tr><td>The heat of a dying star scorches your neck.</td></tr></table>";		print("Doing simulated fight...");		print("");				doFight(test_string, true, false, true);		//string [int] actual_elements = split_string("Stench	Hot	Spooky	Stench	Hot	Physical	Sleaze	Cold	Physical	Spooky	", "\t");
		string [int] actual_elements = split_string("Spooky	Spooky	Physical	Sleaze	Hot	Hot	Cold	Cold	Physical	Stench", "\t");		foreach i in actual_elements			actual_elements[i] = lookupElementHTML(actual_elements[i]);					print_html("That should have been " + componentsJoinedByString(actual_elements, ", "));		print("");				//Test raw HTML string with decodeClues().		string [int] found_clues = decodeClues(test_string, false);		//string [int] actual_clues = split_string("Rotting	skitter	frightening	blackness	shimmers	slowly	48	sanity	7	skull	", "\t");
		string [int] actual_clues = split_string("Horrifying	float	curious	blackness	wobbles	suddenly	3	grasp on reality	14	head	", "\t");				boolean matches = true;		foreach i in actual_clues		{			if (actual_clues[i] != found_clues[i])			{				print("Wrong clue #" + (i + 1) +". Should be \"" + actual_clues[i] + "\", is \"" + found_clues[i] + "\".", "red");				matches = false;			}		}		if (matches)		{			print("Raw HTML clues parsed properly.");		}		print("");
		return;	}		//cannonfire40's spading data:	string [int] lines;	lines[0] = "Rotting	skitter	frightening	blackness	shimmers	slowly	48	sanity	7	skull	";	lines[1] = "Stench	Hot	Spooky	Stench	Hot	Physical	Sleaze	Cold	Physical	Spooky	";	lines[2] = "Chaotic	float	bloated	emptiness	shifts	slowly	9	mind	14	chest	";	lines[3] = "Hot	Spooky	Sleaze	Cold	Sleaze	Spooky	Hot	Cold	Physical	Physical	Stench";	lines[4] = "Rotting	shamble	terrible	darkness	shimmers	slowly	40	eyes	9	skull	";	lines[5] = "Stench	Cold	Hot	Stench	Spooky	Physical	Spooky	Sleaze	Sleaze	Hot	";	lines[6] = "Pulpy	ooze	frightening	void	cracks open	slowly	17	memories	16	heart	";	lines[7] = "Physical	Stench	Spooky	Physical	Stench	Sleaze	Hot	Sleaze	Spooky	Hot	Cold";	lines[8] = "Chaotic	swim	terrible	void	shifts	suddenly	18	sanity	12	brain	";	lines[9] = "Hot	Physical	Hot	Cold	Stench	Cold	Sleaze	Spooky	Spooky	Stench	";	lines[10] = "Pulpy	shamble	terrible	darkness	shimmers	suddenly	32	thoughts	10	skull	";	lines[11] = "Physical	Cold	Hot	Stench	Spooky	Sleaze	Sleaze	Stench	Spooky	Hot	";	lines[12] = "Chaotic	shamble	frightening	blackness	shifts	suddenly	20	grasp on reality	10	head	";	lines[13] = "Hot	Cold	Spooky	Cold	Hot	Stench	Sleaze	Sleaze	Stench	Physical	";	lines[14] = "Slimy	float	curious	portal	wobbles	slowly	5	eyes	24	head	";	lines[15] = "Sleaze	Spooky	Physical	Sleaze	Physical	Stench	Hot	Stench	Hot	Cold	";	lines[16] = "Pulpy	skitter	terrible	Space	shimmers	suddenly	10	memories	6	forehead	";	lines[17] = "Physical	Hot	Hot	Stench	Cold	Cold	Spooky	Sleaze	Sleaze	Stench	Physical";	lines[18] = "Slimy	shamble	frightening	portal	shimmers	suddenly	20	thoughts	18	brain	";	lines[19] = "Sleaze	Cold	Spooky	Stench	Physical	Stench	Sleaze	Spooky	Hot	Physical	Cold";	lines[20] = "Chaotic	slither	terrible	portal	shifts	slowly	6	grasp on reality	14	chest	";	lines[21] = "Hot	Sleaze	Hot	Cold	Physical	Stench	Cold	Sleaze	Spooky	Spooky	";	lines[22] = "Rotting	skitter	frightening	Space	shifts	suddenly	5	thoughts	8	ches